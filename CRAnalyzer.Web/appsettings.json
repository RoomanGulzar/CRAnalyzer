{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=CRAnalyzerDb;Integrated Security=True;TrustServerCertificate=True;MultipleActiveResultSets=true"
  },
  "OpenAI": {
    "ApiKey": "",
    "Model": "gpt-4o",
    "MaxTokens": 4096
  },
  "FileUpload": {
    "MaxFileSizeMb": 10,
    "UploadPath": "uploads"
  },
  "RepositoryScanner": {
    "MaxFileSizeKb": 500,
    "ExcludedDirs": [ ".git", "node_modules", "bin", "obj", ".vs" ]
  }
}
